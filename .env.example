# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Storage (S3 protokolu)
# Supabase Dashboard → Storage → S3 Access Keys
S3_ENDPOINT=https://YOUR_PROJECT.supabase.co/storage/v1/s3
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
S3_BUCKET=property-images
S3_PUBLIC_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public

# Gələcəkdə Cloudflare R2-yə keçid üçün yalnız bunları dəyişin:
# S3_ENDPOINT=https://YOUR_ACCOUNT.r2.cloudflarestorage.com
# S3_PUBLIC_URL=https://images.myroom.az

# Xəritə (Faza 2)
# NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token
